# Web application environment variables
# Copy this file to .env.local and fill in the values from `supabase status`

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_VERSION=0.1.0

# Analytics (optional in development)
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Error monitoring (optional in development)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# Datadog RUM (optional in development)
NEXT_PUBLIC_DD_APPLICATION_ID=
NEXT_PUBLIC_DD_CLIENT_TOKEN=

# Support chat (optional in development)
NEXT_PUBLIC_INTERCOM_APP_ID=

# Feature flags
NEXT_PUBLIC_ENABLE_ANALYTICS=false
