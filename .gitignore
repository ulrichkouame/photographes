# Gitignore for photographes.ci monorepo

# ──────────────────────────────────────────────
# OS files
# ──────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db

# ──────────────────────────────────────────────
# Environment files (never commit secrets)
# ──────────────────────────────────────────────
.env
.env.local
.env.*.local
.env.development.local
.env.test.local
.env.production.local
# Keep .env.example files (they document required variables)
!**/.env.example

# ──────────────────────────────────────────────
# Web — Next.js
# ──────────────────────────────────────────────
apps/web/.next/
apps/web/out/
apps/web/node_modules/
apps/web/coverage/
apps/web/.turbo/
apps/web/playwright-report/
apps/web/test-results/
apps/web/.lighthouseci/

# ──────────────────────────────────────────────
# Mobile — Flutter
# ──────────────────────────────────────────────
apps/mobile/.dart_tool/
apps/mobile/.flutter-plugins
apps/mobile/.flutter-plugins-dependencies
apps/mobile/build/
apps/mobile/android/local.properties
apps/mobile/android/app/keystore.jks
apps/mobile/android/.gradle/
apps/mobile/ios/Pods/
apps/mobile/ios/.symlinks/
apps/mobile/coverage/

# ──────────────────────────────────────────────
# Supabase
# ──────────────────────────────────────────────
supabase/.branches/
supabase/.temp/
supabase/functions/.env
supabase/functions/coverage/

# ──────────────────────────────────────────────
# Editors & IDEs
# ──────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*.suo
*.ntvs*
*.njsproj
*.sln

# ──────────────────────────────────────────────
# Logs
# ──────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# ──────────────────────────────────────────────
# Misc
# ──────────────────────────────────────────────
*.tgz
*.zip
backup.sql
backup.sql.gz
pre-deploy-*.sql.gz

# Flutter (from mobile branch)
# Flutter / Dart
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages
.pub-cache/
.pub/
build/
pubspec.lock
# Android
android/.gradle/
android/captures/
android/local.properties
android/key.properties
*.jks
# iOS
ios/.symlinks/
ios/Flutter/App.framework
ios/Flutter/Flutter.framework
ios/Flutter/Flutter.podspec
ios/Flutter/Generated.xcconfig
ios/Flutter/app.flx
ios/Flutter/app.zip
ios/Flutter/flutter_assets/
ios/Podfile.lock
ios/Pods/
# macOS
macos/Flutter/GeneratedPluginRegistrant.swift
# Web
lib/generated_plugin_registrant.dart
# Firebase
google-services.json
GoogleService-Info.plist
# Secrets / environment
*.env
# IDE
*.iml
*.DS_Store
